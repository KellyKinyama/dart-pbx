# dart-pbx call-center demo — values aligned with the docker-compose
# `asterisk` service (andrius/asterisk:stable, 5060/udp published on
# the host, RTP 10000-20000/udp).

# Listen for SIP from phones on this address/port.
# Must NOT collide with Asterisk's 5060/udp.
UPD_SERVER_ADDRESS=0.0.0.0
UDP_SERVER_PORT=5070

# Asterisk back-end (handles dialplan / voicemail / non-queue calls).
# - 127.0.0.1 if dart-pbx runs on the docker host.
# - `asterisk` if dart-pbx runs in the same compose network.
ASTERISK_HOST=127.0.0.1
ASTERISK_PORT=5060

# Digest auth — must match Asterisk pjsip.conf userpass auth sections.
SIP_REALM=pbx.local
SIP_USERS=6001:6001,6002:6002,7000:7000
# Optional: pin the nonce-signing secret across restarts.
# SIP_AUTH_SECRET=change-me

# SIP proxy mode:
#   stateful  (default) — RFC 3261 §16.10. Keeps transactions/dialogs,
#                         supports forking, ring-timeout serial hunt, etc.
#   stateless           — RFC 3261 §16.11. No transaction or dialog state.
#                         Lower memory, fully transparent, media is never
#                         anchored (RTP flows directly between UA and
#                         Asterisk). REGISTER stays handled by the local
#                         location service either way.
# SIP_PROXY_MODE=stateless

# Call-center: AOR phones dial to reach the queue, plus agent extensions.
CC_QUEUE_AOR=support
CC_AGENTS=6001,6002
