WS_SERVER_ADDRESS=10.100.53.104
WS_SERVER_PORT=8088

# WSS_SERVER_ADDRESS=10.100.54.52
# WSS_SERVER_PORT=8089

# Phones register here. Must NOT collide with Asterisk's 5060/udp.
UPD_SERVER_ADDRESS=0.0.0.0
UDP_SERVER_PORT=5061

# SEC_TCP_SERVER_ADDRESS=10.100.53.101
# SEC_TCP_SERVER_PORT=5068

# TCP_SERVER_ADDRESS=10.100.53.121
# TCP_SERVER_PORT=5069

PATH_TO_CERTIFICATE_FILE_PEM=/etc/ssl/ecdsa/cert.pem
PATH_TO_PRIVATE_KEY_FILE_PEM=/etc/ssl/ecdsa/ec_key.pem

MS_TEAM_DOMAIN=sip.pstnhub.microsoft.com
MS_TEAMS_PORT=443

# ---------------- dart-pbx call-center demo ----------------

# Asterisk back-end (docker compose `asterisk` service, host networking).
# Use 127.0.0.1 if dart-pbx runs on the docker host;
# use the container/service name if dart-pbx runs in the same network.
ASTERISK_HOST=127.0.0.1
ASTERISK_PORT=5060

# Digest auth — must match Asterisk pjsip.conf userpass auth sections.
SIP_REALM=pbx.local
SIP_USERS=6001:6001,6002:6002,7000:7000
# Optional: pin the nonce-signing secret across restarts.
# SIP_AUTH_SECRET=change-me

# Call-center: AOR phones dial to reach the queue, plus agent extensions.
CC_QUEUE_AOR=9000
CC_AGENTS=6001,6002

# Logging: error | warn | info | debug
LOG_LEVEL=debug

# Dump every SIP message that the router can't classify (and every raw
# payload sent through Log.dumpSip) to this file. Comment out to disable.
SIP_DUMP_FILE=logs/sip-dropped.log

